---
---

<div
  id="terminal-window"
  class="term-window"
>
  <!-- Title bar -->
  <div class="term-titlebar">
    <div style="display: flex; gap: 0.45rem; align-items: center;">
      <span class="tl-btn" style="background:#ff5f57;"></span>
      <span class="tl-btn" style="background:#febc2e;"></span>
      <span class="tl-btn" style="background:#28c840;"></span>
    </div>
    <span class="term-title">harshith — fish</span>
  </div>

  <!-- Body -->
  <div
    id="terminal-body"
    class="term-body"
    tabindex="0"
  >
    <div id="terminal-output"></div>

    <!-- Active input line -->
    <div id="terminal-input-line" style="display: flex; align-items: center; gap: 0.35rem; margin-top: 0.1rem;">
      <span id="prompt-icon" class="term-blue" style="flex-shrink:0;">❯</span>
      <div style="position: relative; flex: 1; display: flex; align-items: center;">
        <span id="ghost-text" class="term-ghost" style="position:absolute;left:0;top:0;pointer-events:none;white-space:pre;"></span>
        <span id="input-before-cursor" style="white-space: pre;"></span>
        <span id="terminal-cursor" class="term-cursor"></span>
        <span id="input-after-cursor" style="white-space: pre;"></span>
      </div>
    </div>
  </div>
</div>

<input id="terminal-real-input" type="text"
  style="position:fixed;opacity:0;pointer-events:none;left:-9999px;"
  autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />

<style>
  /* ── Theme tokens ─────────────────────────────────────── */
  .term-window {
    --term-bg:        #f3f4f6;
    --term-titlebar:  #e5e7eb;
    --term-title-fg:  #9ca3af;
    --term-border:    rgba(0,0,0,0.08);
    --term-text:      #1f2937;
    --term-muted:     #9ca3af;
    --term-blue:      #2563eb;
    --term-green:     #16a34a;
    --term-yellow:    #b45309;
    --term-red:       #dc2626;
    --term-ghost:     #d1d5db;
    --term-cursor:    #2563eb;
    --term-tag-bg:    rgba(37,99,235,0.08);
    --term-shadow:    0 8px 30px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.06);
  }

  :global(.dark) .term-window {
    --term-bg:        #141b2d;
    --term-titlebar:  #1e2433;
    --term-title-fg:  #8892a4;
    --term-border:    rgba(255,255,255,0.06);
    --term-text:      #cdd6f4;
    --term-muted:     #6c7086;
    --term-blue:      #89b4fa;
    --term-green:     #a6e3a1;
    --term-yellow:    #f9e2af;
    --term-red:       #f38ba8;
    --term-ghost:     #3d4560;
    --term-cursor:    #89b4fa;
    --term-tag-bg:    rgba(137,180,250,0.1);
    --term-shadow:    0 20px 60px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.06);
  }

  /* ── Structure ────────────────────────────────────────── */
  .term-window {
    border-radius: 12px;
    overflow: hidden;
    margin: 2rem 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    box-shadow: var(--term-shadow);
    background: var(--term-bg);
  }

  .term-titlebar {
    display: flex;
    align-items: center;
    padding: 0.7rem 1rem;
    background: var(--term-titlebar);
    border-bottom: 1px solid var(--term-border);
    position: relative;
  }

  .term-title {
    position: absolute;
    left: 50%; transform: translateX(-50%);
    color: var(--term-title-fg);
    font-size: 0.72rem;
    pointer-events: none;
  }

  .term-body {
    padding: 1rem 1.25rem 1rem;
    background: var(--term-bg);
    min-height: 14rem;
    max-height: 22rem;
    overflow-y: auto;
    line-height: 1.75;
    cursor: text;
    color: var(--term-text);
  }
  .term-body:focus { outline: none; }

  .term-cursor {
    display: inline-block;
    width: 8px; height: 1.1em;
    background: var(--term-cursor);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  .term-ghost { color: var(--term-ghost); }
  .term-blue  { color: var(--term-blue);  }
  .term-green { color: var(--term-green); }
  .term-muted { color: var(--term-muted); }

  .tl-btn {
    width: 12px; height: 12px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0; cursor: default;
    transition: filter 0.15s;
  }
  .tl-btn:hover { filter: brightness(1.15); }

  @keyframes blink {
    0%,100%{opacity:1} 50%{opacity:0}
  }
</style>

<script>
  // ── Color helpers (read from CSS variables, theme-aware) ──
  function tv(name: string) {
    return getComputedStyle(document.getElementById('terminal-window')!).getPropertyValue(name).trim();
  }

  // ── State ────────────────────────────────────────────────
  let buffer = '';
  let cursorPos = 0;
  const history: string[] = [];
  let histIdx = -1;
  let histDraft = '';

  // ── DOM refs ─────────────────────────────────────────────
  const body       = document.getElementById('terminal-body')!;
  const output     = document.getElementById('terminal-output')!;
  const before     = document.getElementById('input-before-cursor')!;
  const after      = document.getElementById('input-after-cursor')!;
  const ghost      = document.getElementById('ghost-text')!;
  const promptIcon = document.getElementById('prompt-icon')!;
  const realInput  = document.getElementById('terminal-real-input') as HTMLInputElement;

  // ── Commands ─────────────────────────────────────────────
  function tv_blue()   { return tv('--term-blue');   }
  function tv_green()  { return tv('--term-green');  }
  function tv_yellow() { return tv('--term-yellow'); }
  function tv_red()    { return tv('--term-red');    }
  function tv_muted()  { return tv('--term-muted');  }
  function tv_text()   { return tv('--term-text');   }
  function tv_ghost()  { return tv('--term-ghost');  }
  function tv_tagbg()  { return tv('--term-tag-bg'); }

  const CMDS: Record<string, () => string[]> = {
    help: () => [
      colorLine('Available commands:', tv_muted()),
      row('help',     'show this message'),
      row('about',    'who am i'),
      row('skills',   'tech i work with'),
      row('projects', 'things i\'ve built'),
      row('contact',  'get in touch'),
      row('neofetch', 'system info'),
      row('ls',       'list "files"'),
      row('clear',    'clear the screen'),
      row('echo',     'print text'),
      '',
      colorLine('tip: ↑/↓ history  •  Tab / → to accept suggestion', tv_ghost()),
    ],
    about: () => [
      colorLine('harshith reddy', tv_blue(), true),
      '',
      line('CS undergrad, linux nerd, builder of things.'),
      line('I write Python and TypeScript, run Arch btw,'),
      line('and spend too much time in tmux sessions.'),
      '',
      kv('location', 'India'),
      kv('status',   'open to work'),
      kv('learning', 'systems programming, ML infra'),
    ],
    skills: () => [
      colorLine('languages', tv_yellow(), true),
      tag('Python') + ' ' + tag('TypeScript') + ' ' + tag('C++') + ' ' + tag('Go'),
      '',
      colorLine('tools & infra', tv_yellow(), true),
      tag('Linux') + ' ' + tag('Docker') + ' ' + tag('Cloudflare') + ' ' + tag('PostgreSQL'),
      '',
      colorLine('ml / ai', tv_yellow(), true),
      tag('PyTorch') + ' ' + tag('YOLOv8') + ' ' + tag('tinygrad') + ' ' + tag('llama.cpp'),
      '',
      colorLine('web', tv_yellow(), true),
      tag('Astro') + ' ' + tag('Node.js') + ' ' + tag('Tailwind'),
    ],
    projects: () => [
      proj('Exam Malpractice Detection', 'shipped', 'YOLOv8 + DBSCAN + ResNet-34'),
      proj('tinygrad — Qwen3 support',   'shipped', 'open source contribution'),
      proj('ErzyCall',                   'shipped', 'WhatsApp chatbot for SMBs'),
      proj('Home Server Stack',          'wip',     'self-hosted infra over Cloudflare'),
      proj('nothr.in',                   'wip',     'this site'),
      '',
      colorLine('run `cat projects/<name>` for details', tv_ghost()),
    ],
    contact: () => [
      kv('email',    'me@nothr.in'),
      kv('github',   'github.com/nothr'),
      kv('x',        'x.com/nothr_in'),
      kv('linkedin', 'linkedin.com/in/mhrsth'),
    ],
    neofetch: () => [
      `<span style="color:${tv_green()};font-weight:600;">harshith</span><span style="color:${tv_ghost()};">@</span><span style="color:${tv_blue()};font-weight:600;">archlinux</span>`,
      `<span style="color:${tv_ghost()};">───────────────────</span>`,
      kv('OS',       'Arch Linux x86_64'),
      kv('WM',       'i3'),
      kv('Shell',    'fish 3.7'),
      kv('Editor',   'nvim'),
      kv('Terminal', 'alacritty'),
      kv('Uptime',   'always on'),
    ],
    ls: () => [
      colorLine('about.txt   projects/   skills.txt   contact.txt', tv_green()),
    ],
    clear: () => { output.innerHTML = ''; return []; },
  };

  const CMD_NAMES = Object.keys(CMDS);

  // ── Helpers ───────────────────────────────────────────────
  function colorLine(t: string, color: string, bold = false) {
    return `<span style="color:${color};${bold ? 'font-weight:600;' : ''}">${t}</span>`;
  }
  function line(t: string) {
    return `<span style="color:${tv_text()};">${t}</span>`;
  }
  function row(cmd: string, desc: string) {
    return `  <span style="color:${tv_blue()};min-width:9ch;display:inline-block;">${cmd}</span><span style="color:${tv_muted()};">${desc}</span>`;
  }
  function kv(k: string, v: string) {
    return `<span style="color:${tv_blue()};">${k.padEnd(9)}</span><span style="color:${tv_text()};">${v}</span>`;
  }
  function tag(t: string) {
    return `<span style="background:${tv_tagbg()};color:${tv_blue()};border-radius:4px;padding:0 5px;">${t}</span>`;
  }
  function proj(name: string, status: string, desc: string) {
    const col = status === 'shipped' ? tv_green() : tv_yellow();
    return `<span style="color:${tv_text()};font-weight:600;">${name}</span> <span style="color:${col};font-size:0.7rem;">[${status}]</span><br><span style="color:${tv_muted()};padding-left:1ch;">${desc}</span>`;
  }

  // ── Render input ──────────────────────────────────────────
  function highlightInput(text: string) {
    if (!text) return text;
    const parts = text.split(' ');
    const isKnown = CMD_NAMES.includes(parts[0]) || parts[0] === 'echo' || parts[0] === 'cat';
    const cmdColor = isKnown ? tv_blue() : tv_red();
    const rest = parts.slice(1).map(p =>
      p.startsWith('-')
        ? `<span style="color:${tv_yellow()};">${p}</span>`
        : `<span style="color:${tv_green()};">${p}</span>`
    ).join(' ');
    return `<span style="color:${cmdColor};">${parts[0]}</span>${rest ? ' ' + rest : ''}`;
  }

  function renderInput() {
    before.innerHTML = highlightInput(buffer.slice(0, cursorPos));
    after.innerHTML  = highlightInput(buffer.slice(cursorPos));
    const sug = getGhostSuggestion();
    ghost.textContent = sug ? buffer + sug.slice(buffer.length) : '';
  }

  function getGhostSuggestion(): string {
    if (!buffer) return '';
    for (let i = history.length - 1; i >= 0; i--) {
      if (history[i].startsWith(buffer) && history[i] !== buffer) return history[i];
    }
    return CMD_NAMES.find(c => c.startsWith(buffer) && c !== buffer) ?? '';
  }

  // ── Print ─────────────────────────────────────────────────
  function printLines(lines: string[]) {
    lines.forEach(l => {
      const div = document.createElement('div');
      div.style.lineHeight = '1.75';
      div.innerHTML = l;
      output.appendChild(div);
    });
    body.scrollTop = body.scrollHeight;
  }

  function printPromptLine(cmd: string) {
    const div = document.createElement('div');
    div.innerHTML = `<span style="color:${tv_blue()};">❯</span> ${highlightInput(cmd)}`;
    output.appendChild(div);
  }

  // ── Execute ───────────────────────────────────────────────
  function execute(raw: string) {
    const cmd = raw.trim();
    printPromptLine(cmd);
    if (!cmd) { body.scrollTop = body.scrollHeight; return; }

    history.push(cmd);
    histIdx = -1; histDraft = '';

    const [name, ...args] = cmd.split(/\s+/);

    if (name === 'echo') {
      printLines([`<span style="color:${tv_text()};">${args.join(' ')}</span>`]);
    } else if (name === 'cat') {
      const file = args[0] ?? '';
      const fake: Record<string, string[]> = {
        'about.txt':   CMDS.about(),
        'skills.txt':  CMDS.skills(),
        'contact.txt': CMDS.contact(),
      };
      printLines(fake[file] ?? [colorLine(`cat: ${file}: No such file or directory`, tv_red())]);
    } else if (CMDS[name]) {
      const result = CMDS[name]();
      if (result.length) printLines(result);
    } else {
      printLines([colorLine(`fish: unknown command: ${name}`, tv_red())]);
    }
    printLines(['']);
  }

  // ── Keyboard ──────────────────────────────────────────────
  body.addEventListener('click', () => realInput.focus());
  body.addEventListener('focus', () => realInput.focus());

  realInput.addEventListener('keydown', (e) => {
    const key = e.key;

    if (key === 'Enter') {
      e.preventDefault();
      const cmd = buffer; buffer = ''; cursorPos = 0; renderInput(); execute(cmd); return;
    }
    if (key === 'Tab') {
      e.preventDefault();
      const sug = getGhostSuggestion();
      if (sug) { buffer = sug; cursorPos = buffer.length; renderInput(); } return;
    }
    if (key === 'ArrowRight') {
      e.preventDefault();
      const sug = getGhostSuggestion();
      if (cursorPos === buffer.length && sug) { buffer += sug[buffer.length]; cursorPos++; }
      else if (cursorPos < buffer.length) cursorPos++;
      renderInput(); return;
    }
    if (key === 'ArrowLeft')  { e.preventDefault(); if (cursorPos > 0) cursorPos--; renderInput(); return; }
    if (key === 'ArrowUp')    {
      e.preventDefault();
      if (!history.length) return;
      if (histIdx === -1) { histDraft = buffer; histIdx = history.length - 1; }
      else if (histIdx > 0) histIdx--;
      buffer = history[histIdx]; cursorPos = buffer.length; renderInput(); return;
    }
    if (key === 'ArrowDown')  {
      e.preventDefault();
      if (histIdx === -1) return;
      histIdx++;
      buffer = histIdx >= history.length ? (histIdx = -1, histDraft) : history[histIdx];
      cursorPos = buffer.length; renderInput(); return;
    }
    if (key === 'Backspace') {
      e.preventDefault();
      if (cursorPos > 0) { buffer = buffer.slice(0, cursorPos - 1) + buffer.slice(cursorPos); cursorPos--; renderInput(); } return;
    }
    if (key === 'Delete') {
      e.preventDefault(); buffer = buffer.slice(0, cursorPos) + buffer.slice(cursorPos + 1); renderInput(); return;
    }
    if (key === 'Home') { cursorPos = 0; renderInput(); e.preventDefault(); return; }
    if (key === 'End')  { cursorPos = buffer.length; renderInput(); e.preventDefault(); return; }
    if (e.ctrlKey) {
      if (key === 'l') { e.preventDefault(); execute('clear'); return; }
      if (key === 'c') { e.preventDefault(); printPromptLine(buffer + '^C'); printLines(['']); buffer = ''; cursorPos = 0; renderInput(); return; }
      if (key === 'u') { e.preventDefault(); buffer = buffer.slice(cursorPos); cursorPos = 0; renderInput(); return; }
      if (key === 'a') { cursorPos = 0; renderInput(); e.preventDefault(); return; }
      if (key === 'e') { cursorPos = buffer.length; renderInput(); e.preventDefault(); return; }
    }
  });

  realInput.addEventListener('input', () => {
    const val = realInput.value;
    if (!val) return;
    buffer = buffer.slice(0, cursorPos) + val + buffer.slice(cursorPos);
    cursorPos += val.length;
    realInput.value = '';
    renderInput();
  });

  // ── Boot ──────────────────────────────────────────────────
  printLines([
    colorLine('Welcome to nothr\'s terminal', tv_blue(), true),
    colorLine('type `help` to see available commands', tv_ghost()),
    '',
  ]);
  renderInput();
</script>
