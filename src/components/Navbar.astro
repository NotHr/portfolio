---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Work', href: '/work' },
  { label: 'Tools', href: '/tools' },
  { label: 'About', href: '/about' },
];

const externalLinks = [
  { label: 'GitHub', href: 'https://github.com/nothr' },
  { label: 'X', href: 'https://x.com/nothr_in' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header>
  <nav class="site-container" style="display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 1.5rem;">

    <!-- Left: nav links -->
    <div style="display: flex; align-items: center; gap: 1rem;">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`nav-link${link.href !== '/' ? ' nav-link--hide-mobile' : ''}`}
            data-active={isActive(link.href) ? 'true' : 'false'}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Right: external links + toggle (hidden mobile) -->
    <div id="nav-right" style="display: flex; align-items: center; gap: 1rem;">
      <button id="cmd-trigger" aria-label="Search" class="search-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>Search pages &amp; posts…</span>
        <kbd class="search-kbd">⌘K</kbd>
      </button>
      {
        externalLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link nav-link--muted"
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>

    <!-- Mobile: hamburger -->
    <button
      id="hamburger"
      aria-label="Open menu"
      style="display: none; background: none; border: none; cursor: pointer; padding: 0.25rem; color: var(--text-muted);"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 8a1 1 0 0 0-1-1H4a1 1 0 0 0 0 2h16a1 1 0 0 0 1-1Zm0 8a1 1 0 0 0-1-1H10a1 1 0 1 0 0 2h10a1 1 0 0 0 1-1Z" />
      </svg>
    </button>

  </nav>
</header>

<style>
  .nav-link {
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: color 0.15s ease;
  }
  .nav-link[data-active='false'] {
    color: var(--text-muted);
  }
  .nav-link--muted {
    color: var(--text-muted);
  }
  .nav-link:hover {
    color: var(--text-primary);
  }

  .search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid var(--border-muted);
    border-radius: 8px;
    padding: 0.375rem 0.75rem;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-family: var(--font-sans);
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    white-space: nowrap;
    min-width: 200px;
    justify-content: space-between;
  }
  .search-btn:hover {
    border-color: var(--border-primary);
    color: var(--text-primary);
    background: var(--surface-hover);
  }

  .search-kbd {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.35rem;
    background: var(--background);
    border: 1px solid var(--border-muted);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .nav-link--hide-mobile {
      display: none;
    }
    #nav-right {
      display: none !important;
    }
    #hamburger {
      display: flex !important;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  if (hamburger) {
    hamburger.addEventListener('click', () => {
      if (typeof (window as any).__openDrawer === 'function') {
        (window as any).__openDrawer();
      }
    });
  }

  document.getElementById('cmd-trigger')?.addEventListener('click', () => {
    document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', ctrlKey: true, bubbles: true }));
  });
</script>
