---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'Tools', href: '/tools' },
  { label: 'About', href: '/about' },
];

const externalLinks = [
  { label: 'GitHub', href: 'https://github.com/nothr' },
  { label: 'X', href: 'https://x.com/nothr_in' },
];
---

<div
  id="mobile-drawer"
  style="
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    pointer-events: none;
  "
>
  <!-- Overlay -->
  <div
    id="drawer-overlay"
    style="position: absolute; inset: 0; background: rgb(0 0 0 / 0.4);"
  ></div>

  <!-- Panel -->
  <div
    id="drawer-panel"
    style="
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 14rem;
      background: var(--background);
      border-left: 1px solid var(--border-muted);
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    "
  >
    <!-- Close button -->
    <div style="display: flex; justify-content: flex-end; margin-bottom: 1.5rem;">
      <button
        id="drawer-close"
        aria-label="Close menu"
        style="background: none; border: none; cursor: pointer; color: var(--text-muted); padding: 0.25rem;"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path
            d="M4 4l10 10M14 4L4 14"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <div style="display: flex; flex-direction: column; gap: 0.875rem; flex: 1;">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            style={`font-size: 0.9375rem; text-decoration: none; color: ${pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) ? 'var(--text-primary)' : 'var(--text-muted)'};`}
          >
            {link.label}
          </a>
        ))
      }
      <div style="height: 1px; background: var(--border-muted); margin: 0.25rem 0;"></div>
      {
        externalLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            style="font-size: 0.9375rem; text-decoration: none; color: var(--text-muted);"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Theme toggle at bottom -->
    <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.8125rem;">
      <ThemeToggle />
      <span>Toggle theme</span>
    </div>
  </div>
</div>

<script>
  const drawer = document.getElementById('mobile-drawer');
  const panel = document.getElementById('drawer-panel');
  const overlay = document.getElementById('drawer-overlay');
  const closeBtn = document.getElementById('drawer-close');

  function openDrawer() {
    if (!drawer || !panel) return;
    drawer.style.display = 'block';
    drawer.style.pointerEvents = 'auto';
    requestAnimationFrame(() => {
      if (panel) panel.style.transform = 'translateX(0)';
    });
  }

  function closeDrawer() {
    if (!drawer || !panel) return;
    panel.style.transform = 'translateX(100%)';
    setTimeout(() => {
      if (drawer) {
        drawer.style.display = 'none';
        drawer.style.pointerEvents = 'none';
      }
    }, 300);
  }

  // expose openDrawer globally so Navbar can call it
  (window as any).__openDrawer = openDrawer;

  overlay?.addEventListener('click', closeDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
</script>
